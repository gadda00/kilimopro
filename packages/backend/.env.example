# KilimoPRO Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kilimopro?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Data Source APIs
# FAOSTAT
FAOSTAT_API_URL="https://api.fao.org/api/v1"
FAOSTAT_API_KEY=""

# Google Earth Engine
GEE_PROJECT_ID=""
GEE_SERVICE_ACCOUNT_EMAIL=""
GEE_PRIVATE_KEY=""

# OpenWeatherMap
OPENWEATHER_API_KEY=""

# Africa's Talking (SMS/USSD)
AT_USERNAME=""
AT_API_KEY=""
AT_SENDER_ID="KILIMO"

# KALRO / KAOP (requires partnership)
KAOP_API_URL=""
KAOP_API_KEY=""

# KilimoSTAT
KILIMOSTAT_BASE_URL="https://statistics.kilimo.go.ke"

# LLM API (for advisory & NLQ)
LLM_API_URL="https://open.bigmodel.cn/api/paas/v4"
LLM_API_KEY=""

# Crop Disease Model
DISEASE_MODEL_PATH="./assets/models/crop_disease_v1.tflite"
DISEASE_LABELS_PATH="./assets/models/labels.json"

# Firecrawl (web scraping for ag content)
FIRECRAWL_API_KEY=""

# Semantic Scholar API (agricultural research)
# No API key required for free tier (rate limited)
S2_API_BASE="https://api.semanticscholar.org/graph/v1"

# yt-dlp (educational video downloads)
YT_DLP_PATH="yt-dlp"
VIDEO_STORAGE_PATH="./assets/videos"

# KilimoSTAT API (official Kenya ag stats)
KILIMOSTAT_API_KEY=""

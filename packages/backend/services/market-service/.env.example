# Market Service Configuration

# Server Configuration
PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://kilimo.pro

# Database Configuration
DATABASE_URL=postgresql://kilimopro:kilimopro@localhost:5432/kilimopro

# Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_PRICES=900
CACHE_TTL_TRENDS=3600
CACHE_TTL_FORECASTS=1800

# Message Queue Configuration
NATS_SERVERS=nats://localhost:4222

# API Configuration
SWAGGER_HOST=localhost:3003
IS_PRODUCTION=false

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# External API Keys
AIRC_API_KEY=your_airc_api_key
FAOSTAT_API_KEY=your_faostat_api_key
OPENWEATHER_API_KEY=your_openweather_api_key

# Market Data Sources
AIRC_BASE_URL=https://airc.kilimo.go.ke/api
FAOSTAT_BASE_URL=http://www.fao.org/faostat/en

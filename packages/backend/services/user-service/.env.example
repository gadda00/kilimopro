# User Service Configuration

# Server Configuration
PORT=3004
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://kilimo.pro

# Database Configuration
DATABASE_URL=postgresql://kilimopro:kilimopro@localhost:5432/kilimopro

# Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SESSIONS=300
CACHE_TTL_USERS=3600

# Message Queue Configuration
NATS_SERVERS=nats://localhost:4222

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
SWAGGER_HOST=localhost:3004
IS_PRODUCTION=false

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# Password Configuration
BCRYPT_ROUNDS=12

# Service URLs

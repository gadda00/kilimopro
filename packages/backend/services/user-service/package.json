{
  "name": "@kilimopro/user-service",
  "version": "1.0.0",
  "description": "KilimoPRO User Service - User management and authentication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "docker:build": "docker build -t kilimopro/user-service .",
    "docker:run": "docker run -p 3004:3004 kilimopro/user-service"

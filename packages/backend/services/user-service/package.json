    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^4.00",
    "@kilimopro/cache-client": "1.0.0",
    "@kilimopro/db-client": "1.0.0",
    "@kilimopro/logger": "1.0.0",
    "@kilimopro/message-queue": "1.0.0",
    "@kilimopro/shared-types": "1.0.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
